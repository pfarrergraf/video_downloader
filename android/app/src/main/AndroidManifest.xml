<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required by WebView's network stack even for 127.0.0.1-only traffic. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- The three permissions below were explicitly approved by the repo
         owner on 2026-07-07 (CLAUDE.md permission guardrail; rationale in
         docs/ANDROID_PERMISSIONS_2026-07-07.md). Purpose: downloads must
         survive the user switching apps / turning the screen off, with a
         progress notification and a tappable "download finished"
         notification — the DownloadService foreground service. All three
         are standard for download managers (Seal/YTDLnis use the same set);
         none grant access to any user data. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- allowBackup=false: Android's Auto Backup would otherwise restore this
         app's internal storage (queue database, and MainActivity's
         per-install random password in SharedPreferences) on a fresh
         install, defeating both "uninstalling truly resets everything" and
         the per-install-password design (see getOrCreatePassword()'s
         comment) - a restored password is no longer unique to this install. -->
    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.ClassyDL"
        android:networkSecurityConfig="@xml/network_security_config">
        <!-- singleTask: a "Share -> DownloadThat" while the app is already
             running must route into the existing instance via onNewIntent()
             (which owns the one Python server process) instead of stacking a
             second Activity that would race the port-8420 bind. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share target: lets YouTube/TikTok/Instagram/etc. share a link
                 straight into the app (the 2-tap download flow). Deliberately
                 NO ACTION_VIEW filter - that would make Android offer
                 "Open with DownloadThat" for every web link, which is exactly
                 the kind of chooser noise non-technical users find confusing.
                 Note: an intent-filter is not a permission; the app's
                 permission footprint is unchanged (INTERNET only). -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Hosts the Python server + downloads outside the Activity
             lifecycle; dataSync is the canonical type for user-initiated
             transfers. Not exported: nothing outside this app may start it. -->
        <service
            android:name=".DownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Lets android_bridge.open_file() hand a finished download to another
             app (e.g. a video player) without exposing a raw file:// Uri, which
             targetSdk 24+ blocks with a FileUriExposedException. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="de.classydl.app.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
